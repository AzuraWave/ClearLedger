@page
@model PresentationLayer.Pages.OrganizationPages.Dashboard.IndexModel
@{
}
<style>
    .table-fixed {
        table-layout: fixed;
        width: 100%;
        word-wrap: break-word;
    }

    .text-truncate {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
</style>


<h2 class="px-4">Dashboard</h2>

<div class="row mb-4 px-4">
    <div class="col-md-3">
        <div class="card text-white bg-primary mb-3">
            <div class="card-body">
                <h5 class="card-title">Total Clients</h5>
                <p class="card-text display-6">@Model.TotalClients</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success mb-3">
            <div class="card-body">
                <h5 class="card-title">Total Projects</h5>
                <p class="card-text display-6">@Model.TotalProjects</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-warning mb-3">
            <div class="card-body">
                <h5 class="card-title">Total Balance</h5>
                <p class="card-text display-6">$@Model.TotalBalance</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-danger mb-3">
            <div class="card-body">
                <h5 class="card-title">Total Invoices This Month</h5>
                <p class="card-text display-6">$@Model.TotalInvoices</p>
            </div>
        </div>
    </div>
</div>

<h3 class="px-4">Recent Transactions</h3>
<div class="px-4">
    <div class="card shadow-sm mt-3">
        <div class="card-body">

            @if (Model.RecentTransactions?.Items?.Any() == true)
            {
                <table class="table table-striped table-fixed">
                    <thead>
                        <tr>
                            <th style="width:150px;">Date</th>
                            <th style="width:200px;">Client</th>
                            <th style="width:300px;">Project</th>
                            <th style="width:150px;">Type</th>
                            <th style="width:150px;" class="text-end">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var tx in Model.RecentTransactions.Items)
                        {
                            <tr>
                                <td>@tx.Date.ToString("yyyy-MM-dd")</td>
                                <td class="text-truncate">@tx.ClientName</td>
                                <td class="text-truncate">@tx.ProjectName</td>
                                <td>@tx.Type</td>
                                <td class="text-end">
                                    @tx.Amount.ToString("C", new System.Globalization.CultureInfo("en-US")
                                    {
                                        NumberFormat = { CurrencyNegativePattern = 1 }
                                    })
                        </td>
                    </tr>
                                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="alert alert-info mb-0">
                    No recent transactions.
                </div>
            }

        </div>
    </div>
</div>