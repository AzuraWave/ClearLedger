@page
@using DomainLayer.Enums
@model PresentationLayer.Pages.Customer.Projects.IndexModel
@{
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-12 col-xl-10">

<div class="card shadow-sm border-2 px-1">
    <div class="card-body p-0">

        <div class="px-4  pb-2">
            <h4 class="mb-0">Projects</h4>
        </div>

        <form method="get" class="row g-2 px-4 pb-3">
            <div class="col-md-6">
                <input type="text"
                       name="Search"
                       class="form-control"
                       placeholder="Search projects..."
                       value="@Model.Search" />
            </div>

            <div class="col-md-3">
                <select asp-for="Status"
                        class="form-select"
                        onchange="this.form.submit()">
                    <option value="">All Status</option>
                    <option value="Active">Active</option>
                    <option value="Completed">Completed</option>
                    <option value="Archived">Archived</option>
                </select>
            </div>

            <div class="col-md-3 d-grid">
                <button type="submit" class="btn btn-primary">
                    Filter
                </button>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Project</th>
                        <th class="text-end">Balance</th>
                        <th class="text-center">Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model.Projects?.Any() ?? false)
                    {
                        foreach (var project in Model.Projects)
                        {
                            <tr>
                                <td class="fw-semibold">
                                    @project.Name
                                </td>

                                <td class="text-end fw-semibold">
                                    @project.Balance.ToString("C")
                                </td>

                                <td class="text-center">
                                    @switch (project.ProjectStatus)
                                    {
                                        case ProjectStatus.Active:
                                            <span class="badge bg-success px-3">Active</span>
                                            break;
                                        case ProjectStatus.Completed:
                                            <span class="badge bg-primary px-3">Completed</span>
                                            break;
                                        case ProjectStatus.Archived:
                                            <span class="badge bg-secondary px-3">Archived</span>
                                            break;
                                    }
                                </td>

                                <td class="text-end">
                                    <a asp-page="/Customer/Projects/Details"
                                       asp-route-id="@project.Id"
                                       class="btn btn-sm btn-outline-primary">
                                        View
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4"
                                class="text-center text-muted py-4">
                                No projects found for this client.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>

                                    </div>
    </div>
</div>