@page
@model PresentationLayer.Pages.Customer.Statement.IndexModel
@{
}
<div class="container mt-4">

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h4 class="mb-3">Generate Statement</h4>

            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label asp-for="From" class="form-label">From</label>
                    <input type="date" asp-for="From" class="form-control" />
                </div>

                <div class="col-md-3">
                    <label asp-for="To" class="form-label">To</label>
                    <input type="date" asp-for="To" class="form-control" />
                </div>

                <div class="col-md-auto">
                    <button type="submit" class="btn btn-primary mt-1">Generate</button>
                </div>
            </form>
        </div>
    </div>

    @if (Model.Statement != null)
    {
        <div class="card shadow-sm mb-4">
            <div class="card-body">

                <h5 class="mb-3">Statement</h5>

                <p><strong>Opening Balance:</strong> @Model.Statement.OpeningBalance.ToString("C")</p>

                <div class="table-responsive">
                    <table class="table table-striped table-bordered align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Date</th>
                                <th>Project</th>
                                <th>Type</th>
                                <th>Reference</th>
                                <th class="text-end">Amount</th>
                                <th class="text-end">Balance</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tx in Model.Statement.Transactions)
                            {
                                <tr>
                                    <td>@tx.Date:yyyy-MM-dd</td>
                                    <td>@tx.ProjectName</td>
                                    <td>@tx.Type</td>
                                    <td>@tx.Reference</td>
                                    <td class="text-end">
                                        @tx.Amount.ToString("C", new System.Globalization.CultureInfo("en-US") { NumberFormat = { CurrencyNegativePattern = 1 } })
                                    </td>
                                    <td class="text-end">
                                        @tx.RunningBalance.ToString("C", new System.Globalization.CultureInfo("en-US") { NumberFormat = { CurrencyNegativePattern = 1 } })
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <p class="mt-3"><strong>Closing Balance:</strong> @Model.Statement.Transactions.LastOrDefault()?.RunningBalance.ToString("C")</p>

                <div class="mt-4 d-flex gap-2 justify-content-end">
                    <a asp-page-handler="PrintPdf"
                       asp-route-clientId="@Model.ClientId"
                       asp-route-from="@Model.From?.ToString("yyyy-MM-dd")"
                       asp-route-to="@Model.To?.ToString("yyyy-MM-dd")"
                       class="btn btn-outline-primary">
                        Export PDF
                    </a>

                    <a asp-page-handler="ExportExcel"
                       asp-route-clientId="@Model.ClientId"
                       asp-route-from="@Model.From?.ToString("yyyy-MM-dd")"
                       asp-route-to="@Model.To?.ToString("yyyy-MM-dd")"
                       class="btn btn-outline-success">
                        Export Excel
                    </a>
                </div>
            </div>
        </div>
    }
</div>